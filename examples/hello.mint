program init.
  var texto type string = "Mint".
  var num type int = 3.
  var ok type bool = true.
  var price type float = 10.5.
  var letter type char = 'A'.
initialization.
  write("Olá!").
  write(texto).
  write(num).
  write(ok).
  write(price / 2).
  write(letter).
  write((num + 2) * 5).
endprogram.

{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Mint",
  "scopeName": "source.mint",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#fieldAccess"
    },
    {
      "include": "#booleans"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#punctuation"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.mint",
          "match": "//.*$"
        },
        {
          "name": "comment.line.quote.mint",
          "match": "^\\s*\".*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.mint",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.mint",
              "match": "\\\\(n|t|\"|\\\\)"
            }
          ]
        },
        {
          "name": "string.quoted.single.mint",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.mint",
              "match": "\\\\(n|t|'|\\\\)"
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.mint",
          "match": "\\b(program|init|initialization|endprogram|if|elseif|else|endif|while|endwhile|for|in|endfor|try|catch|endtry|func|endfunc|return|returns|input|move|to|load|save|export|query|from|where|into|LOAD|SAVE|EXPORT|TO|QUERY|FROM|WHERE|INTO|FOR|IN|ENDFOR|TRY|CATCH|ENDTRY|struct|endstruct|STRUCT|ENDSTRUCT|add|insert|size|count|sum|avg|import|IMPORT)\\b"
        },
        {
          "name": "keyword.operator.logical.mint",
          "match": "\\b(and|or|not)\\b"
        },
        {
          "name": "keyword.declaration.mint",
          "match": "\\b(var|type)\\b"
        },
        {
          "name": "entity.name.function.mint",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()"
        },
        {
          "name": "support.function.mint",
          "match": "\\b(write|input|move|to|load|save|export|query|from|where|into|add|insert|size|count|sum|avg|import|IMPORT)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.mint",
          "match": "\\b(int|string|bool|float|char|list|table)\\b"
        }
      ]
    },
    "fieldAccess": {
      "patterns": [
        {
          "name": "meta.field.access.mint",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\.([A-Za-z_][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "variable.other.mint"
            },
            "2": {
              "name": "variable.other.property.mint"
            }
          }
        }
      ]
    },
    "booleans": {
      "patterns": [
        {
          "name": "constant.language.boolean.mint",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.mint",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.mint",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arithmetic.mint",
          "match": "(==|!=|<=|>=|<|>|\\+|\\-|\\*|\\/|=)"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.terminator.mint",
          "match": "\\."
        },
        {
          "name": "punctuation.parenthesis.mint",
          "match": "(\\(|\\)|\\[|\\]|<|>)"
        }
      ]
    }
  }
}
